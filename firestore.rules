rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function notModerated(roomId) {
      return !exists(/databases/$(database)/documents/rooms/$(roomId)/moderation/$(request.auth.uid))
        || get(/databases/$(database)/documents/rooms/$(roomId)/moderation/$(request.auth.uid)).data.bannedUntil <= request.time.toMillis();
    }

    function notBanned(roomId) {
      return !exists(/databases/$(database)/documents/rooms/$(roomId)/moderation/$(request.auth.uid))
        || get(/databases/$(database)/documents/rooms/$(roomId)/moderation/$(request.auth.uid)).data.action != "ban"
        || get(/databases/$(database)/documents/rooms/$(roomId)/moderation/$(request.auth.uid)).data.bannedUntil <= request.time.toMillis();
    }

    function claimedUsernameMatches(roomId, usernameKey, displayName) {
      return usernameKey is string
        && usernameKey.matches('[a-z0-9][a-z0-9_-]{2,23}')
        && exists(/databases/$(database)/documents/rooms/$(roomId)/usernames/$(usernameKey))
        && get(/databases/$(database)/documents/rooms/$(roomId)/usernames/$(usernameKey)).data.authorId == request.auth.uid
        && get(/databases/$(database)/documents/rooms/$(roomId)/usernames/$(usernameKey)).data.displayName == displayName;
    }

    function validMessagePayload(roomId) {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "authorName",
          "audioDurationMs",
          "audioMimeType",
          "audioUrl",
          "attachments",
          "accentColor",
          "avatar",
          "authorIsAnonymous",
          "banner",
          "body",
          "clientCreatedAt",
          "createdAt",
          "messageType",
          "replyToId",
          "soundKind",
          "usernameKey",
          "waveform"
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 4000
        && request.resource.data.messageType is string
        && request.resource.data.messageType in ["text", "audio"]
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() <= 6
        && (
          request.resource.data.body.size() > 0
          || request.resource.data.attachments.size() > 0
          || request.resource.data.messageType == "audio"
        )
        && request.resource.data.audioUrl is string
        && request.resource.data.audioUrl.size() <= 4096
        && request.resource.data.audioMimeType is string
        && request.resource.data.audioMimeType.size() <= 80
        && request.resource.data.audioDurationMs is number
        && request.resource.data.audioDurationMs >= 0
        && request.resource.data.audioDurationMs <= 120000
        && request.resource.data.accentColor is string
        && (
          request.resource.data.accentColor == ""
          || request.resource.data.accentColor.matches('#[0-9A-Fa-f]{6}')
        )
        && request.resource.data.authorIsAnonymous is bool
        && request.resource.data.banner is string
        && request.resource.data.banner.size() <= 800000
        && request.resource.data.clientCreatedAt is number
        && request.resource.data.createdAt == request.time
        && request.resource.data.avatar is string
        && request.resource.data.avatar.size() <= 800000
        && request.resource.data.replyToId is string
        && request.resource.data.soundKind is string
        && claimedUsernameMatches(
          roomId,
          request.resource.data.usernameKey,
          request.resource.data.authorName
        )
        && request.resource.data.waveform is list
        && request.resource.data.waveform.size() <= 80;
    }

    function validMessagePinUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "pinnedAt"
        ])
        && (
          !request.resource.data.keys().hasAny(["pinnedAt"])
          || (
            request.resource.data.pinnedAt is number
            && request.resource.data.pinnedAt > 0
            && request.resource.data.pinnedAt <= request.time.toMillis()
          )
        );
    }

    function validReactionPayload(roomId) {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "authorName",
          "clientCreatedAt",
          "createdAt",
          "emoji",
          "messageId",
          "usernameKey"
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.clientCreatedAt is number
        && request.resource.data.createdAt == request.time
        && request.resource.data.emoji is string
        && request.resource.data.emoji.size() > 0
        && request.resource.data.emoji.size() <= 8
        && request.resource.data.messageId is string
        && request.resource.data.messageId.size() > 0
        && request.resource.data.messageId.size() <= 160
        && claimedUsernameMatches(
          roomId,
          request.resource.data.usernameKey,
          request.resource.data.authorName
        );
    }

    function validModerationPayload() {
      return request.resource.data.keys().hasOnly([
          "action",
          "authorId",
          "authorName",
          "bannedUntil",
          "clientCreatedAt",
          "createdAt",
          "moderatorId",
          "moderatorName",
          "reason"
        ])
        && request.resource.data.action is string
        && request.resource.data.action in ["timeout", "ban"]
        && request.resource.data.authorId is string
        && request.resource.data.authorId.size() > 0
        && request.resource.data.authorId.size() <= 160
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.bannedUntil is number
        && request.resource.data.bannedUntil > request.time.toMillis()
        && request.resource.data.clientCreatedAt is number
        && request.resource.data.createdAt == request.time
        && request.resource.data.moderatorId == request.auth.uid
        && request.resource.data.moderatorName is string
        && request.resource.data.moderatorName.size() > 0
        && request.resource.data.moderatorName.size() <= 80
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 280;
    }

    function validUsernamePayload(usernameKey) {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "clientUpdatedAt",
          "displayName",
          "isAnonymous",
          "updatedAt",
          "usernameKey"
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.clientUpdatedAt is number
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 3
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.displayName.matches('[A-Za-z0-9 _-]{3,40}')
        && request.resource.data.isAnonymous is bool
        && request.resource.data.updatedAt == request.time
        && request.resource.data.usernameKey == usernameKey
        && request.resource.data.usernameKey.matches('[a-z0-9][a-z0-9_-]{2,23}');
    }

    function validStoredUsernameClaim(userId) {
      return request.resource.data.usernameClaim == null
        || (
          request.resource.data.usernameClaim is map
          && request.resource.data.usernameClaim.keys().hasOnly([
            "authorId",
            "key",
            "name"
          ])
          && request.resource.data.usernameClaim.authorId == userId
          && request.resource.data.usernameClaim.key is string
          && request.resource.data.usernameClaim.key.matches('[a-z0-9][a-z0-9_-]{2,23}')
          && request.resource.data.usernameClaim.name is string
          && request.resource.data.usernameClaim.name.size() >= 3
          && request.resource.data.usernameClaim.name.size() <= 40
          && request.resource.data.usernameClaim.name.matches('[A-Za-z0-9 _-]{3,40}')
        );
    }

    function validPreferenceProfile(profile) {
      return profile is map
        && profile.keys().hasOnly([
          "accentColor",
          "avatar",
          "banner",
          "joinedAt",
          "name",
          "statusText"
        ])
        && profile.name is string
        && profile.name.size() > 0
        && profile.name.size() <= 80
        && profile.avatar is string
        && profile.avatar.size() <= 800000
        && profile.banner is string
        && profile.banner.size() <= 800000
        && profile.accentColor is string
        && profile.accentColor.matches('#[0-9A-Fa-f]{6}')
        && profile.joinedAt is number
        && profile.statusText is string
        && profile.statusText.size() <= 80;
    }

    function validPreferenceNotifications(notifications) {
      return notifications is map
        && notifications.keys().hasOnly([
          "attachmentPreviews",
          "browserEnabled",
          "keywordAlerts",
          "mentionSummary",
          "roomEnabled",
          "soundKinds",
          "soundsEnabled",
          "uiSound",
          "uiSoundsEnabled",
          "voicePreviews"
        ])
        && notifications.attachmentPreviews is bool
        && notifications.browserEnabled is bool
        && notifications.keywordAlerts is list
        && notifications.keywordAlerts.size() <= 20
        && notifications.mentionSummary is bool
        && notifications.roomEnabled is bool
        && notifications.soundsEnabled is bool
        && notifications.uiSoundsEnabled is bool
        && notifications.uiSound is string
        && notifications.uiSound in [
          "click",
          "deafen",
          "done",
          "mute",
          "pop",
          "soft"
        ]
        && notifications.voicePreviews is bool
        && notifications.soundKinds is map
        && notifications.soundKinds.keys().hasOnly([
          "message",
          "ping",
          "reply"
        ])
        && notifications.soundKinds.message is bool
        && notifications.soundKinds.ping is bool
        && notifications.soundKinds.reply is bool;
    }

    function validPreferenceRoomSettings(roomSettings) {
      return roomSettings is map
        && roomSettings.keys().hasOnly([
          "announcement",
          "archived",
          "audioPlaybackRate",
          "compactMode",
          "imageCompressionQuality",
          "reducedData",
          "role",
          "topic"
        ])
        && roomSettings.announcement is string
        && roomSettings.announcement.size() <= 220
        && roomSettings.archived is bool
        && roomSettings.audioPlaybackRate is number
        && roomSettings.audioPlaybackRate >= 0.5
        && roomSettings.audioPlaybackRate <= 2
        && roomSettings.compactMode is bool
        && roomSettings.imageCompressionQuality is number
        && roomSettings.imageCompressionQuality >= 0.45
        && roomSettings.imageCompressionQuality <= 0.95
        && roomSettings.reducedData is bool
        && roomSettings.role is string
        && roomSettings.role in ["owner", "admin", "trusted", "guest"]
        && roomSettings.topic is string
        && roomSettings.topic.size() > 0
        && roomSettings.topic.size() <= 90;
    }

    function validPreferenceModerationSettings(moderationSettings) {
      return moderationSettings is map
        && moderationSettings.keys().hasOnly([
          "reasonPreset",
          "slowModeSeconds",
          "warningExpiresMinutes",
          "wordFilterMode",
          "wordFilterWords"
        ])
        && moderationSettings.reasonPreset is string
        && moderationSettings.reasonPreset.size() > 0
        && moderationSettings.reasonPreset.size() <= 120
        && moderationSettings.slowModeSeconds is number
        && moderationSettings.slowModeSeconds >= 0
        && moderationSettings.slowModeSeconds <= 120
        && moderationSettings.warningExpiresMinutes is number
        && moderationSettings.warningExpiresMinutes >= 1
        && moderationSettings.warningExpiresMinutes <= 60
        && moderationSettings.wordFilterMode is string
        && moderationSettings.wordFilterMode in ["off", "warn", "block"]
        && moderationSettings.wordFilterWords is list
        && moderationSettings.wordFilterWords.size() <= 50;
    }

    function validUserPreferencesPayload(userId) {
      return userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "blockedUserIds",
          "clientUpdatedAt",
          "moderationSettings",
          "notifications",
          "profile",
          "roomSettings",
          "starredMessageIds",
          "trustedSites",
          "updatedAt",
          "usernameClaim",
          "version"
        ])
        && request.resource.data.clientUpdatedAt is number
        && request.resource.data.updatedAt == request.time
        && request.resource.data.version is number
        && validPreferenceProfile(request.resource.data.profile)
        && validPreferenceNotifications(request.resource.data.notifications)
        && validPreferenceRoomSettings(request.resource.data.roomSettings)
        && validPreferenceModerationSettings(request.resource.data.moderationSettings)
        && request.resource.data.blockedUserIds is list
        && request.resource.data.blockedUserIds.size() <= 500
        && request.resource.data.starredMessageIds is list
        && request.resource.data.starredMessageIds.size() <= 500
        && request.resource.data.trustedSites is list
        && request.resource.data.trustedSites.size() <= 50
        && validStoredUsernameClaim(userId);
    }

    function validVoicePresencePayload(roomId) {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "avatar",
          "cameraOn",
          "clientUpdatedAt",
          "isAnonymous",
          "joinedAt",
          "lastSeenAt",
          "name",
          "speaking",
          "updatedAt",
          "usernameKey"
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.avatar is string
        && request.resource.data.avatar.size() <= 800000
        && request.resource.data.cameraOn is bool
        && request.resource.data.clientUpdatedAt is number
        && request.resource.data.isAnonymous is bool
        && request.resource.data.joinedAt is number
        && request.resource.data.lastSeenAt is number
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && claimedUsernameMatches(
          roomId,
          request.resource.data.usernameKey,
          request.resource.data.name
        )
        && request.resource.data.speaking is bool
        && request.resource.data.updatedAt == request.time;
    }

    function validVoiceSignalPayload() {
      return request.resource.data.keys().hasOnly([
          "candidate",
          "clientCreatedAt",
          "createdAt",
          "from",
          "sdp",
          "to",
          "type"
        ])
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to.size() > 0
        && request.resource.data.to.size() <= 160
        && request.resource.data.to != request.auth.uid
        && request.resource.data.type is string
        && request.resource.data.type in ["offer", "answer", "candidate"]
        && request.resource.data.clientCreatedAt is number
        && request.resource.data.createdAt == request.time
        && (
          (request.resource.data.type == "candidate"
            && request.resource.data.candidate is map
            && request.resource.data.sdp == null)
          || (request.resource.data.type in ["offer", "answer"]
            && request.resource.data.sdp is map
            && request.resource.data.candidate == null)
        );
    }

    function validVoiceKickPayload() {
      return request.resource.data.keys().hasOnly([
          "authorId",
          "clientCreatedAt",
          "createdAt",
          "kickedUntil",
          "moderatorId",
          "moderatorName",
          "reason"
        ])
        && request.resource.data.authorId is string
        && request.resource.data.authorId.size() > 0
        && request.resource.data.authorId.size() <= 160
        && request.resource.data.clientCreatedAt is number
        && request.resource.data.createdAt == request.time
        && request.resource.data.kickedUntil is number
        && request.resource.data.kickedUntil > request.time.toMillis()
        && request.resource.data.kickedUntil <= request.time.toMillis() + 10 * 60 * 1000
        && request.resource.data.moderatorId == request.auth.uid
        && request.resource.data.moderatorName is string
        && request.resource.data.moderatorName.size() > 0
        && request.resource.data.moderatorName.size() <= 80
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 180;
    }

    match /users/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create, update: if signedIn() && validUserPreferencesPayload(userId);
      allow delete: if signedIn() && userId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow write: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && notBanned(roomId);
        allow create: if signedIn() && notModerated(roomId) && validMessagePayload(roomId);
        allow update: if signedIn() && notModerated(roomId) && validMessagePinUpdate();
        allow delete: if signedIn();
      }

      match /reactions/{reactionId} {
        allow read: if signedIn() && notBanned(roomId);
        allow create: if signedIn() && notModerated(roomId) && validReactionPayload(roomId);
        allow update: if signedIn()
          && resource.data.authorId == request.auth.uid
          && notModerated(roomId)
          && validReactionPayload(roomId);
        allow delete: if signedIn();
      }

      match /moderation/{authorId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && validModerationPayload();
        allow delete: if signedIn();
      }

      match /usernames/{usernameKey} {
        allow read: if signedIn();
        allow create: if signedIn() && notModerated(roomId) && validUsernamePayload(usernameKey);
        allow update: if signedIn()
          && resource.data.authorId == request.auth.uid
          && notModerated(roomId)
          && validUsernamePayload(usernameKey);
        allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
      }

      match /voiceParticipants/{authorId} {
        allow read: if signedIn() && notBanned(roomId);
        allow create, update: if signedIn()
          && authorId == request.auth.uid
          && notModerated(roomId)
          && validVoicePresencePayload(roomId);
        allow delete: if signedIn();
      }

      match /voiceKicks/{authorId} {
        allow read: if signedIn() && authorId == request.auth.uid;
        allow create, update: if signedIn()
          && request.resource.data.authorId == authorId
          && validVoiceKickPayload();
        allow delete: if signedIn();
      }

      match /voiceSignals/{signalId} {
        allow read: if signedIn()
          && notBanned(roomId)
          && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
        allow create: if signedIn() && notModerated(roomId) && validVoiceSignalPayload();
        allow update: if false;
        allow delete: if signedIn();
      }

      match /files/{fileId} {
        allow read: if signedIn() && notBanned(roomId);
        allow create: if false;
        allow update, delete: if false;

        match /chunks/{chunkId} {
          allow read: if signedIn() && notBanned(roomId);
          allow create: if false;
          allow update, delete: if false;
        }
      }
    }
  }
}
